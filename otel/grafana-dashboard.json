{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "title": "trashmonitor",
  "tags": ["trashmonitor", "tailnet"],
  "time": { "from": "now-3h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "pod ready replicas",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_ready{namespace=\"trashmonitor\",deployment=\"trashmonitor\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "ready paths",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(paths{state=\"ready\"})", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "inbound bytes/s per path",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(paths_inbound_bytes[1m])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "type": "timeseries",
      "title": "active RTSP publish sessions",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (path) (rtsp_sessions{state=\"publish\"})",
          "legendFormat": "{{ path }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HLS readers per path",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "paths_readers",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    }
  ]
}
