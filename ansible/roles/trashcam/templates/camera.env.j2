{{ ansible_managed | comment }}
# /etc/trashcam/{{ item.id }}.env — generated by ansible role 'trashcam'

CAMERA_DEV={{ item.device }}
PUSH_URL=rtsp://{{ trashcam_push_host }}:{{ trashcam_push_port }}/{{ item.id }}
FPS={{ item.fps | default(5) }}
QUALITY={{ item.quality | default(8) }}
WIDTH={{ item.width | default(640) }}
HEIGHT={{ item.height | default(480) }}
