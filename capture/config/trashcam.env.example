# /etc/trashcam/<id>.env — schema reference for trashcam@<id>.service
#
# In normal use these files are generated by the ansible role
# `roles/trashcam/templates/camera.env.j2` from per-host inventory.
# This example exists as a schema reference for manual ops.

CAMERA_DEV=/dev/video0
PUSH_URL=rtsp://trashmonitor-rtsp.<your-tailnet>.ts.net:8554/<id>
FPS=5
QUALITY=8
WIDTH=640
HEIGHT=480
